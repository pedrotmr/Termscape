#!/usr/bin/env bash
set -euo pipefail

# SwiftFormat + SwiftLint before each commit (same pins as CI via tooling/tool-versions).

ROOT="$(git rev-parse --show-toplevel)"
cd "${ROOT}"

if [[ ! -f "${ROOT}/tooling/tool-versions" ]]; then
  echo "pre-commit: tooling/tool-versions not found." >&2
  exit 1
fi

bash "${ROOT}/Scripts/ci/bootstrap-tooling.sh"
export PATH="${ROOT}/build/ci-tools/bin:${PATH}"

echo "pre-commit: SwiftFormat…"
swiftformat Sources Tests

# Stage formatting changes so they land in the commit you are creating.
git add -u Sources Tests

echo "pre-commit: SwiftLint…"
swiftlint lint
